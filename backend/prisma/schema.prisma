generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MonsterAttribute {
  DARK
  LIGHT
  WATER
  FIRE
  EARTH
  WIND
  DIVINE
}

enum MonsterType {
  Aqua
  Beast
  BeastWarrior
  CreatorGod
  Cyberse
  Dinosaur
  DivineBeast
  Dragon
  Fairy
  Fiend
  Fish
  Insect
  Machine
  Plant
  Psychic
  Pyro
  Reptile
  Rock
  SeaSerpent
  Spellcaster
  Thunder
  Warrior
  WingedBeast
  Wyrm
  Zombie
  Normal
  Effect
  Fusion
  Ritual
  Synchro
  Xyz
  Pendulum
  Link
  Tuner
  Token
  Flip
  Toon
  Spirit
  Union
  Gemini
}

enum Duelist {
  YugiMuto           @map("Yugi Muto")
  TristanTaylor      @map("Tristan Taylor")
  JoeyWheeler        @map("Joey Wheeler")
  RyouBakura         @map("Ryou Bakura")
  WeevilUnderwood    @map("Weevil Underwood")
  RexRaptor          @map("Rex Raptor")
  MakoTsunami        @map("Mako Tsunami")
  MaiValentine       @map("Mai Valentine")
  SetoKaiba          @map("Seto Kaiba")
  MokubaKaiba        @map("Mokuba Kaiba")
  Puppeteer
  PaniK
  BanditKeith        @map("Bandit Keith")
  SimonMuran         @map("Simon Muran")
  MaximillionPegasus @map("Maximillion Pegasus")
  YamiYugi           @map("Yami Yugi")
}

enum SpellType {
  Normal
  Continuous
  Equip
  QuickPlay @map("Quick-Play")
  Field
  Ritual
}

model Spell {
  id          Int       @id @default(autoincrement())
  name        String
  cardNumber  Int?      @map("card_number")
  type        SpellType
  description String
  imageUrl    String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([name])
  @@map("spells")
}

model Monster {
  id            Int              @id @default(autoincrement())
  name          String
  monsterNumber Int?     @map("monster_number")
  attribute     MonsterAttribute
  monsterLevel  Int?
  type          MonsterType[]
  description   String?
  attackPoints  Int?
  defensePoints Int?
  imageUrl      String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  fusionResults       FusionRecipe[]         @relation("ResultMonster")
  fusionMaterials     FusionRecipeMaterial[] @relation("MaterialMonster")
  monsterCardDrops    MonsterCardDrop[]      @relation("MonsterCardDrops")
  monsterVictoryBonuses MonsterVictoryBonus[] @relation("MonsterVictoryBonuses")

  @@unique([name])
  @@map("monsters")
}

model FusionRecipe {
  id              Int      @id @default(autoincrement())
  resultMonsterId Int      @map("result_monster_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  resultMonster Monster                @relation("ResultMonster", fields: [resultMonsterId], references: [id])
  materials     FusionRecipeMaterial[]

  @@map("fusion_recipes")
}

model FusionRecipeMaterial {
  id                Int      @id @default(autoincrement())
  fusionRecipeId    Int      @map("fusion_recipe_id")
  materialMonsterId Int      @map("material_monster_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  fusionRecipe    FusionRecipe @relation(fields: [fusionRecipeId], references: [id])
  materialMonster Monster      @relation("MaterialMonster", fields: [materialMonsterId], references: [id])

  @@map("fusion_recipe_materials")
}

model MonsterCardDrop {
  id          Int      @id @default(autoincrement())
  duelistName Duelist  @map("duelist_name")
  monsterId   Int      @map("monster_id")
  dropChance  Float    @map("drop_chance")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  monster Monster @relation("MonsterCardDrops", fields: [monsterId], references: [id])

  @@map("monster_card_drops")
}

model MonsterVictoryBonus {
  id           Int      @id @default(autoincrement())
  duelistName  Duelist  @map("duelist_name")
  monsterId    Int      @map("monster_id")
  winsRequired Int      @map("wins_required")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  monster Monster @relation("MonsterVictoryBonuses", fields: [monsterId], references: [id])

  @@map("monster_victory_bonuses")
}